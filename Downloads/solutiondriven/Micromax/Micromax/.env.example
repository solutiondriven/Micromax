# Micromax Trading API - Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (contains passwords)

# ============================================
# MT5 CONNECTION (Primary Account - Your Bot)
# ============================================

# MT5 Account number (visible in MT5 terminal top-left)
MT5_ACCOUNT=123456

# MT5 Account password (your MT5 login password)
MT5_PASSWORD=your_mt5_password

# MT5 Server name (depends on broker)
# Examples:
# - Exness Real: "Exness-Real2"
# - Exness Demo: "Exness-Demo"
# - IC Markets Demo: "ICMarkets-Demo01"
# - IC Markets Live: "ICMarkets-Live"
# - Pepperstone Demo: "Pepperstone-Demo"
# - Pepperstone Live: "Pepperstone-Live"
# - FXOpen Demo: "FXOpen-Demo"
# - FXOpen Real: "FXOpen-Real"
MT5_SERVER=Exness-Demo

# ============================================
# COPY TRADING (Followers - Optional)
# ============================================

# Enable copy trading (true/false)
COPY_TRADING_ENABLED=false

# Follower account 1
FOLLOWER_1_ACCOUNT=
FOLLOWER_1_PASSWORD=
FOLLOWER_1_SERVER=

# Follower account 2
FOLLOWER_2_ACCOUNT=
FOLLOWER_2_PASSWORD=
FOLLOWER_2_SERVER=

# ============================================
# API SERVER
# ============================================

# API server port
PORT=3000

# API server host
HOST=localhost

# CORS allowed origins (for frontend)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# FRAMEWORK & LOGGING
# ============================================

# Node environment
NODE_ENV=development

# Log level (error, warn, info, debug, verbose)
LOG_LEVEL=info

# ============================================
# FRONTEND
# ============================================

# Frontend URL (for redirects, CORS)
FRONTEND_URL=http://localhost:5173

# API Base URL (what frontend calls)
API_BASE_URL=http://localhost:3000/api

# ============================================
# OPTIONAL: ADVANCED SETTINGS
# ============================================

# Python path (if not in system PATH)
PYTHON_PATH=python3

# MT5 initialization timeout (ms)
MT5_TIMEOUT=30000

# Max positions allowed
MAX_POSITIONS=10

# Default lot size if not specified
DEFAULT_VOLUME=0.1

# ============================================
# NOTES FOR SETUP
# ============================================

# 1. Download MT5 from your broker:
#    - Exness: https://exness.com/download/
#    - IC Markets: https://icmarkets.com/download/
#    - Pepperstone: https://pepperstone.com/download/
#
# 2. Install and log in to MT5
#
# 3. Get your account details:
#    - Account number: See MT5 window title or top-left
#    - Password: Your MT5 login password
#    - Server: See in MT5 when logging in
#
# 4. Enable algorithmic trading:
#    - Tools → Options → Expert Advisors
#    - ✅ Enable Expert Advisors
#    - ✅ Enable DLL Imports
#    - ✅ Allow live trading (if real account)
#
# 5. Copy this file to .env and fill in YOUR values
#
# 6. Start API server:
#    npm run dev
#
# 7. Test connection:
#    curl -X POST http://localhost:3000/api/mt5/connect
# Local development only: retry MetaApi requests without TLS verification
# if your machine/network injects a self-signed certificate.
METAAPI_ALLOW_SELF_SIGNED_CERTS=false
